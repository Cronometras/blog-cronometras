---
import Base from "@/layouts/Base.astro";
import ContactForm from "@/components/react/ContactFormEn";
---

<Base title="Contact | Cronometras App">
  <section class="section">
    <div class="container">
      <div class="row justify-center mb-10">
        <div class="md:col-10 lg:col-8 text-center">
          <h1 class="text-3xl font-bold mb-4">Contact Us</h1>
          <p class="text-lg text-gray-700 dark:text-gray-300">
            Do you have any questions or comments? Don't hesitate to get in touch with us.
            We'll be happy to help you.
          </p>
        </div>
      </div>

      <div class="row justify-center">
        <div class="md:col-10 lg:col-8">
          <div class="rounded-xl bg-white dark:bg-gray-800 p-6 shadow-lg md:p-8">
            <ContactForm client:load />
          </div>
        </div>
      </div>

      <div class="row justify-center mt-16">
        <div class="md:col-10 lg:col-9 flex flex-wrap">
          <div class="w-full p-4 md:w-1/3">
            <div class="rounded-lg bg-white dark:bg-gray-800 p-6 text-center shadow hover:shadow-lg transition-shadow">
              <div class="mb-4 inline-flex h-16 w-16 items-center justify-center rounded-full bg-accent/10 text-accent">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-mail"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              </div>
              <h4 class="mb-3 text-xl font-semibold">Email</h4>
              <p class="mb-4 text-gray-600 dark:text-gray-300">
                info@cronometras.com
              </p>
              <a href="mailto:info@cronometras.com" class="text-accent hover:underline">
                Send email
              </a>
            </div>
          </div>

          <div class="w-full p-4 md:w-1/3">
            <div class="rounded-lg bg-white dark:bg-gray-800 p-6 text-center shadow hover:shadow-lg transition-shadow">
              <div class="mb-4 inline-flex h-16 w-16 items-center justify-center rounded-full bg-accent/10 text-accent">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-phone"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              </div>
              <h4 class="mb-3 text-xl font-semibold">Phone</h4>
              <p class="mb-4 text-gray-600 dark:text-gray-300">
                +34 619 58 82 39
              </p>
              <a href="tel:+34619588239" class="text-accent hover:underline">
                Call
              </a>
            </div>
          </div>

          <div class="w-full p-4 md:w-1/3">
            <div class="rounded-lg bg-white dark:bg-gray-800 p-6 text-center shadow hover:shadow-lg transition-shadow">
              <div class="mb-4 inline-flex h-16 w-16 items-center justify-center rounded-full bg-accent/10 text-accent">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.498 14.382v3.3a1 1 0 0 1-1.09 1 15.09 15.09 0 0 1-6.53-2.32 15.5 15.5 0 0 1-4.69-4.69 15.09 15.09 0 0 1-2.32-6.53 1 1 0 0 1 1-1.09h3.3a1 1 0 0 1 1 .9c.14 1.22.46 2.4.94 3.5a1 1 0 0 1-.21 1.07l-1.4 1.4a12 12 0 0 0 4.5 4.5l1.4-1.4a1 1 0 0 1 1.07-.21c1.1.48 2.28.8 3.5.94a1 1 0 0 1 .9 1.1z"/>
                </svg>
              </div>
              <h4 class="mb-3 text-xl font-semibold">WhatsApp</h4>
              <p class="mb-4 text-gray-600 dark:text-gray-300">
                +34 619 58 82 39
              </p>
              <a href="https://wa.me/34619588239?text=Hello%2C%20I'm%20contacting%20you%20through%20the%20Cronometras%20App%20website" target="_blank" class="text-accent hover:underline">
                Send message
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
