---
import type { CollectionEntry } from 'astro:content';
import config from '@/config/config.json';

interface Props {
  post: CollectionEntry<'blog'>;
  url: URL;
}

const { post, url } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, author, category, tags } = post.data;

// Construir la URL canónica completa — si el post tiene canonical_url propia
// (por ser duplicado de otro canónico), se respeta.
const canonicalUrl = post.data.canonical_url
  ? post.data.canonical_url
  : new URL(url.pathname, config.site.base_url).toString();

// Obtener el idioma del post
const slugValue = post.slug || post.id || '';
const lang = slugValue.split('/')[0];

// Fechas normalizadas a ISO 8601
const publishedISO = (pubDate instanceof Date && !isNaN(pubDate.getTime()) ? pubDate : new Date()).toISOString();
const modifiedISO = updatedDate && updatedDate instanceof Date && !isNaN(updatedDate.getTime())
  ? updatedDate.toISOString()
  : publishedISO;

// Imagen del post
const heroImageUrl = heroImage
  ? new URL(heroImage, config.site.base_url).toString()
  : new URL("/images/webp/og-default.png", config.site.base_url).toString();

// Construir el esquema JSON-LD para BlogPosting
const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  },
  "headline": title,
  "name": title,
  "description": description,
  "image": [heroImageUrl],
  "datePublished": publishedISO,
  "dateModified": modifiedISO,
  "inLanguage": lang === 'es' ? 'es-ES' : 'en-US',
  "author": {
    "@type": "Person",
    "name": author,
    "url": config.site.base_url
  },
  "publisher": {
    "@type": "Organization",
    "@id": `${config.site.base_url}/#organization`,
    "name": "CRONOMETRAS",
    "logo": {
      "@type": "ImageObject",
      "url": new URL("/images/webp/logo-2.webp", config.site.base_url).toString(),
      "width": 192,
      "height": 192
    }
  }
};

// Añadir categoría y etiquetas si están disponibles
if (category) {
  schema.articleSection = category;
}
if (tags && tags.length > 0) {
  schema.keywords = tags.join(', ');
}

// Proteger JSON-LD contra inyecciones (XSS en crawlers)
const schemaString = JSON.stringify(schema).replace(/</g, "\\u003c");
---

<!-- Schema BlogPosting (JSON-LD) — apunta a la canónica si existe -->
<script type="application/ld+json" set:html={schemaString} />

<!-- Si el post es un duplicado de otro canónico, lo marcamos como noindex y
     dejamos que Base.astro emita el <link rel="canonical"> hacia la canónica. -->
