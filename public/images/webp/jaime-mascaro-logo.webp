<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 120" width="300" height="120">
  <!-- Círculo con las iniciales JM -->
  <circle cx="60" cy="60" r="35" fill="none" stroke="#000000" stroke-width="2"/>
  <text x="60" y="50" font-family="serif" font-size="16" font-weight="normal" text-anchor="middle" fill="#000000">J</text>
  <text x="60" y="75" font-family="serif" font-size="16" font-weight="normal" text-anchor="middle" fill="#000000">M</text>
  
  <!-- Texto JAIME MASCARÓ -->
  <text x="120" y="45" font-family="serif" font-size="20" font-weight="normal" fill="#000000" letter-spacing="2px">JAIME MASCARÓ</text>
  
  <!-- Texto MENORCA 1918 -->
  <text x="120" y="70" font-family="serif" font-size="12" font-weight="normal" fill="#666666" letter-spacing="3px">MENORCA 1918</text>
</svg>