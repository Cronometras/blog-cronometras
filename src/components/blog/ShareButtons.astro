---
// ShareButtons.astro
// Componente optimizado y moderno para compartir posts en redes sociales (Especialmente X y LinkedIn)
import { IoLogoFacebook, IoLogoLinkedin, IoLogoWhatsapp, IoLink } from "react-icons/io5";
import { FaXTwitter } from "react-icons/fa6";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

interface Props {
  url: URL;
  title: string;
  description?: string;
}

const { url, title, description = "" } = Astro.props;

// Asegurar URL absoluta
const shareUrl = url.href;
const encodedUrl = encodeURIComponent(shareUrl);
const encodedTitle = encodeURIComponent(title);
const encodedDescription = encodeURIComponent(description);

// Obtener traducciones según el idioma
const lang = getLangFromUrl(url);
const t = useTranslations(lang);

// URLs modernas para compartir
const facebookShareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
const xShareUrl = `https://x.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`;
// Endpoint clásico de LinkedIn que procesa mejor los datos explícitos cuando el scraper de OG tags falla en entornos locales o de desarrollo
const sourceUrl = url.origin || 'https://cronometras.com';
const linkedinShareUrl = `https://www.linkedin.com/shareArticle?mini=true&url=${encodedUrl}&title=${encodedTitle}&summary=${encodedDescription}&source=Cronometras&source_url=${encodeURIComponent(sourceUrl)}`;
const whatsappShareUrl = `https://wa.me/?text=${encodedTitle}%20${encodedUrl}`;

const copyToClipboardScript = `
  function copyToClipboard() {
    navigator.clipboard.writeText('${shareUrl}').then(function() {
      const tooltip = document.getElementById('copy-tooltip');
      const originalText = tooltip.textContent;
      tooltip.textContent = '${t('share.copied')}';
      tooltip.classList.add('bg-green-600');
      tooltip.classList.remove('bg-gray-800');
      setTimeout(function() {
        tooltip.textContent = '${t('share.copy') || 'Copiar link'}';
        tooltip.classList.remove('bg-green-600');
        tooltip.classList.add('bg-gray-800');
      }, 2000);
    });
  }
`;
---

<div class="my-10 w-full rounded-2xl bg-gray-50/50 p-6 sm:p-8 dark:bg-gray-800/20 border border-gray-100 dark:border-gray-800 flex flex-col md:flex-row items-center justify-between gap-6 transition-all duration-300 hover:shadow-sm">
  <div class="text-center md:text-left">
    <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-1">
      {lang === 'es' ? '¿Te ha parecido útil?' : 'Did you find this useful?'}
    </h3>
    <p class="text-sm text-gray-500 dark:text-gray-400">
      {lang === 'es' ? 'Comparte este artículo con tu red profesional' : 'Share this article with your professional network'}
    </p>
  </div>

  <div class="flex flex-wrap items-center justify-center gap-3">
    <!-- LinkedIn (Principal) -->
    <a
      href={linkedinShareUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="group flex items-center gap-2 rounded-full bg-[#0077b5]/10 px-5 py-2.5 text-[#0077b5] transition-all hover:bg-[#0077b5] hover:text-white dark:bg-[#0077b5]/20"
      aria-label="Share on LinkedIn"
      onclick="window.open(this.href, 'linkedin-share', 'width=580,height=520,toolbar=0,menubar=0,location=0,status=0,scrollbars=1,resizable=1'); return false;"
    >
      <IoLogoLinkedin className="h-5 w-5" />
      <span class="font-medium text-sm">LinkedIn</span>
    </a>

    <!-- X (Twitter) -->
    <a
      href={xShareUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="group flex items-center justify-center h-10 w-10 md:h-11 md:w-11 rounded-full bg-gray-100 text-gray-700 transition-all hover:bg-black hover:text-white dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-white dark:hover:text-black"
      aria-label="Share on X"
      onclick="window.open(this.href, 'x-share', 'width=580,height=520,toolbar=0,menubar=0,location=0,status=0,scrollbars=1,resizable=1'); return false;"
    >
      <FaXTwitter className="h-4 w-4 md:h-5 md:w-5" />
    </a>

    <!-- Facebook -->
    <a
      href={facebookShareUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="group flex items-center justify-center h-10 w-10 md:h-11 md:w-11 rounded-full bg-gray-100 text-gray-700 transition-all hover:bg-[#1877f2] hover:text-white dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-[#1877f2]"
      aria-label="Share on Facebook"
      onclick="window.open(this.href, 'fb-share', 'width=580,height=520,toolbar=0,menubar=0,location=0,status=0,scrollbars=1,resizable=1'); return false;"
    >
      <IoLogoFacebook className="h-5 w-5 md:h-6 md:w-6" />
    </a>

    <!-- WhatsApp -->
    <a
      href={whatsappShareUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="group flex items-center justify-center h-10 w-10 md:h-11 md:w-11 rounded-full bg-gray-100 text-gray-700 transition-all hover:bg-[#25d366] hover:text-white dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-[#25d366]"
      aria-label="Share on WhatsApp"
      onclick="window.open(this.href, 'wa-share', 'width=580,height=520,toolbar=0,menubar=0,location=0,status=0,scrollbars=1,resizable=1'); return false;"
    >
      <IoLogoWhatsapp className="h-5 w-5 md:h-6 md:w-6 text-current pl-0.5" />
    </a>

    <!-- Copiar Link -->
    <div class="relative flex items-center mt-2 md:mt-0">
      <button
        onclick="copyToClipboard()"
        class="peer flex items-center justify-center h-10 w-10 md:h-11 md:w-11 rounded-full bg-gray-100 text-gray-700 transition-all hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-accent/50"
        aria-label="Copy link"
      >
        <IoLink className="h-5 w-5" />
      </button>
      <div id="copy-tooltip" class="absolute -top-10 left-1/2 -translate-x-1/2 px-3 py-1.5 bg-gray-800 text-white text-xs font-medium rounded shadow-lg opacity-0 transition-opacity pointer-events-none peer-hover:opacity-100 whitespace-nowrap z-10">
        {t('share.copy') || 'Copiar link'}
      </div>
      <!-- Triangle/Arrow for tooltip -->
      <div class="absolute -top-3 left-1/2 -translate-x-1/2 border-4 border-transparent border-t-gray-800 opacity-0 transition-opacity peer-hover:opacity-100 pointer-events-none z-10"></div>
    </div>
  </div>
</div>

<script is:inline set:html={copyToClipboardScript}></script>

<script>
  // Añadir log de analytics al hacer clic en cualquier botón de compartir (usando module syntax de Astro)
  document.addEventListener('astro:page-load', () => {
    const shareLinks = document.querySelectorAll('a[href*="share"], a[href*="intent"], a[href*="wa.me"]');
    
    shareLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        let network = 'Unknown';
        const href = link.getAttribute('href') || '';
        if (href.includes('linkedin')) network = 'LinkedIn';
        if (href.includes('x.com')) network = 'X (Twitter)';
        if (href.includes('facebook')) network = 'Facebook';
        if (href.includes('wa.me')) network = 'WhatsApp';

        console.log(`Compartiendo artículo via ${network}`);
        
        // Google Analytics Event (if defined)
        if ('gtag' in window) {
          (window as any).gtag('event', 'share', {
            'method': network,
            'content_type': 'article',
            'item_id': window.location.pathname
          });
        }
      });
    });
  });
</script>
