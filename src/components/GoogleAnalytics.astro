---
// GoogleAnalytics.astro — UNICA fuente de inicialización de gtag en el sitio.
// Antes había un snippet inline duplicado en Base.astro que machacaba el dataLayer
// y rompía el handshake con GA4 cuando la env var GTAG_ID no existía en CF Pages
// (gtag('config', undefined) → 0 sesiones). Ahora este componente es el único punto
// de inicialización, vive en el <head>, y siempre tiene fallback hardcoded.
//
// Patrón: Consent Mode v2 + cookieless pings (ver skill seo-geo-optimization,
// references/consent-mode-v2-cookieless-pings-2026-06-24.md). Por defecto analytics
// está 'denied' y CookieConsent.astro actualiza a 'granted' si el usuario acepta.
// gtag.js SE CARGA SIEMPRE para que GA4 pueda modelar el tráfico de usuarios que
// rechazan cookies (requiere toggles Google signals + Attribution modeling en el
// panel de GA4).
const GA_ID = import.meta.env.GTAG_ID
  || import.meta.env.GOOGLE_ANALYTICS_ID
  || 'G-7FCEX5D4FF';
---

<!-- Google tag (gtag.js) — consent mode v2 + cookieless pings -->
<script is:inline define:vars={{ GA_ID }}>
  window.GTAG_ID = GA_ID;
  window.dataLayer = window.dataLayer || [];
  window.gtag = function gtag(){ dataLayer.push(arguments); };

  // Estado por defecto: NO consentir analítica. CookieConsent.astro actualizará
  // analytics_storage a 'granted' sólo si el usuario acepta.
  gtag('consent', 'default', {
    'analytics_storage': 'denied',
    'ad_storage': 'denied',
    'ad_user_data': 'denied',
    'ad_personalization': 'denied',
    'wait_for_update': 500
  });
  gtag('js', new Date());
  gtag('config', GA_ID, {
    'send_page_view': true,
    'transport_type': 'beacon',
    'anonymize_ip': true
  });

  // Cargar gtag.js SIEMPRE (no solo si hay consentimiento) para que GA4 pueda
  // modelar el tráfico de usuarios que rechazan cookies. Se ejecuta tras window
  // onload para priorizar el render del contenido.
  window.addEventListener('load', function() {
    try {
      loadGtagScript();
    } catch (e) { /* si falla, seguimos sin tracking */ }
  });

  // Expuesto globalmente para que CookieConsent.astro lo llame al aceptar cookies.
  window.loadGtagScript = function() {
    if (document.getElementById('gtag-js')) return;
    var s = document.createElement('script');
    s.id = 'gtag-js';
    s.async = true;
    s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
    document.head.appendChild(s);

    setTimeout(function() {
      window.gtag('event', 'page_view', {
        page_title: document.title,
        page_location: window.location.href,
        page_path: window.location.pathname
      });
    }, 100);
  };
</script>
<script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>