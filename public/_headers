# Cloudflare Pages _headers
# Documentación: https://developers.cloudflare.com/pages/configuration/headers/
# Cada bloque tiene:
#   <ruta>   <- ruta a la que se aplica (soporta * como wildcard)
#   <header> <- header a aplicar (uno por línea)
# Las reglas más específicas van primero.

# ---------------------------------------------------------------------
# 1. Seguridad global — todas las páginas
# ---------------------------------------------------------------------
/*
  # Forzar HTTPS por 1 año (incluye subdominios y precarga)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  # Prevenir MIME-sniffing
  X-Content-Type-Options: nosniff
  # No permitir embedding (anti-clickjacking)
  X-Frame-Options: DENY
  # Política de referrers conservadora
  Referrer-Policy: strict-origin-when-cross-origin
  # Política de permisos: deshabilitar APIs sensibles que no usamos
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), interest-cohort=()
  # Política de seguridad de contenido
  # Notas:
  #   - 'unsafe-inline' en script-src es necesario porque Astro inyecta
  #     estilos críticos y el script de consentimiento de cookies inline.
  #     Para endurecer más, mover a nonces/hashes.
  #   - fonts.googleapis.com y fonts.gstatic.com son para la fuente de marca
  #   - www.googletagmanager.com y www.google-analytics.com son para GA4
  #   - cdn.jsdelivr.net es para KaTeX (matemáticas en posts)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://www.google-analytics.com https://*.analytics.google.com https://*.google-analytics.com; frame-ancestors 'none'; form-action 'self'; base-uri 'self'
  # Habilitar XSS filter (legacy browsers)
  X-XSS-Protection: 1; mode=block

# ---------------------------------------------------------------------
# 2. Cache agresivo para assets estáticos (fotos, fonts)
# ---------------------------------------------------------------------
/images/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.ico
  Cache-Control: public, max-age=2592000

# ---------------------------------------------------------------------
# 3. Robots en páginas de bajo valor (login, checkout, admin)
# ---------------------------------------------------------------------
/es/login
  X-Robots-Tag: noindex, nofollow

/en/login
  X-Robots-Tag: noindex, nofollow

/es/registro
  X-Robots-Tag: noindex, nofollow

/en/register
  X-Robots-Tag: noindex, nofollow

/es/mi-cuenta
  X-Robots-Tag: noindex, nofollow

/en/my-account
  X-Robots-Tag: noindex, nofollow

/es/checkout
  X-Robots-Tag: noindex, nofollow

/en/checkout
  X-Robots-Tag: noindex, nofollow

# ---------------------------------------------------------------------
# 4. Content-Type correcto para archivos de texto plano (LLM feeds)
# ---------------------------------------------------------------------
/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600

/llms-full.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600

/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400
